#!/bin/sh
# ── bspwmrc ──────────────────────────────────────────────────────────────────

# ── monitors & workspaces ────────────────────────────────────────────────────
bspc monitor -d I II III IV V VI VII VIII IX X

# ── global settings ──────────────────────────────────────────────────────────
bspc config border_width          2
bspc config window_gap            12
bspc config split_ratio           0.52
bspc config borderless_monocle    true
bspc config gapless_monocle       false
bspc config focus_follows_pointer true
bspc config pointer_follows_focus false

# ── colours ──────────────────────────────────────────────────────────────────
bspc config normal_border_color   "#1e1e2e"
bspc config active_border_color   "#313244"
bspc config focused_border_color  "#cba6f7"
bspc config presel_feedback_color "#45475a"

# ── window rules ─────────────────────────────────────────────────────────────
bspc rule -a Gimp           state=floating
bspc rule -a Pavucontrol    state=floating rectangle=600x400+0+0 center=true
bspc rule -a \*:fzf-menu    state=floating rectangle=700x400+0+0 center=true
bspc rule -a Thunar         state=floating rectangle=900x600+0+0 center=true
bspc rule -a feh            state=floating
bspc rule -a Nm-applet      manage=off

# ── autostart ────────────────────────────────────────────────────────────────

# wallpaper
if command -v feh >/dev/null 2>&1; then
  WP=$(ls "$HOME/.local/share/wallpapers/"*.{jpg,jpeg,png} 2>/dev/null | shuf -n1)
  [ -n "$WP" ] && feh --no-fehbg --bg-fill "$WP" &
fi

# compositor
if command -v picom >/dev/null 2>&1; then
  pkill -x picom 2>/dev/null; sleep 0.3
  picom --config "$HOME/.config/picom/picom.conf" --daemon
fi

# polybar
"$HOME/.config/polybar/launch.sh" &

# sxhkd (restart if already running)
pkill -x sxhkd 2>/dev/null; sleep 0.1
sxhkd -c "$HOME/.config/sxhkd/sxhkdrc" &
